<div class="chat-page">

  <header class="chat-header">
    <div class="chat-header__icon">
      <i class="fa-solid fa-wand-magic-sparkles"></i>
    </div>
    <div>
      <p class="chat-header__eyebrow">RECOMMENDATION ASSISTANT</p>
      <h1 class="chat-header__title">matIA <span class="chat-header__chat-id">- chat #<%= @chat.id %></span></h1>
    </div>
  </header>

  <div class="chat-messages" id="chat-messages">
    <% @messages.each do |message| %>
      <div class="chat-message chat-message--<%= message.role %>">
        <div class="chat-bubble chat-bubble--<%= message.role %>">
          <%= message.content %>
        </div>
        <% if message.game.present? %>
          <%= render "chats/recommendation_card", game: message.game, chat: @chat %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="chat-input-bar">
    <%= form_with url: chat_messages_path(@chat), data: { turbo: true }, class: "chat-input-form" do |f| %>
      <%= f.text_field :content,
          name: "message[content]",
          placeholder: "Tell matIA what you're craving...",
          class: "chat-input",
          autocomplete: "off",
          id: "message-input" %>
      <%= f.button type: "submit", class: "chat-send-btn" do %>
        <i class="fa-solid fa-paper-plane"></i>
      <% end %>
    <% end %>
  </div>

</div>

<script>
  // Scroll to bottom on load
  const el = document.getElementById('chat-messages');
  if (el) el.scrollTop = el.scrollHeight;

  // Clear input after submit
  document.querySelector('.chat-input-form')?.addEventListener('turbo:submit-end', () => {
    document.getElementById('message-input').value = '';
  });
</script>
