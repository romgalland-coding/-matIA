<div class="profile-page px-4 pt-5">

  <%# Header %>
  <div class="profile-header mb-5">
    <div class="profile-avatar">
      <%= current_user.user_name.first(2).upcase %>
    </div>
    <div>
      <h1 class="profile-title">My profile</h1>
      <p class="profile-subtitle">Manage your account &amp; devices</p>
    </div>
  </div>

  <%# Account fields %>
  <div class="d-flex flex-column gap-3 mb-5">
    <div class="profile-field">
      <label class="form-label">Gamertag</label>
      <div class="profile-field__row">
        <div class="profile-field__value"><%= @user.user_name %></div>
        <%= link_to edit_profile_path(anchor: "user_name"), class: "profile-field__edit" do %>
          <i class="fa-solid fa-pen-to-square"></i> Edit
        <% end %>
      </div>
    </div>

    <div class="profile-field">
      <label class="form-label">Email</label>
      <div class="profile-field__row">
        <div class="profile-field__value"><%= @user.email %></div>
        <%= link_to edit_profile_path(anchor: "email"), class: "profile-field__edit" do %>
          <i class="fa-solid fa-pen-to-square"></i> Edit
        <% end %>
      </div>
    </div>

    <div class="profile-field">
      <label class="form-label">Password</label>
      <div class="profile-field__row">
        <div class="profile-field__value">••••••••••</div>
        <%= link_to edit_profile_path(anchor: "password"), class: "profile-field__edit" do %>
          <i class="fa-solid fa-pen-to-square"></i> Edit
        <% end %>
      </div>
    </div>
  </div>

  <%# Devices %>
  <div class="mb-5">
    <label class="form-label">My devices</label>
    <% if @user.devices.present? %>
      <div class="d-flex flex-wrap gap-2 mb-3">
        <% @user.devices.each do |device| %>
          <span class="chip chip-yellow"><%= device %></span>
        <% end %>
      </div>
    <% else %>
      <p class="profile-empty-devices">No devices added yet.</p>
    <% end %>
    <%= link_to edit_profile_path(anchor: "devices"), class: "profile-add-device" do %>
      <i class="fa-solid fa-plus"></i> Add device
    <% end %>
  </div>

  <%# Actions %>
  <div class="d-flex flex-column gap-3">
    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-danger w-100 py-3" do %>
      <i class="fa-solid fa-right-from-bracket me-2"></i>Log out
    <% end %>

    <button class="profile-delete-link" data-bs-toggle="collapse" data-bs-target="#confirm-delete">
      <i class="fa-solid fa-trash"></i> Delete account
    </button>

    <div class="collapse" id="confirm-delete">
      <div class="profile-delete-confirm">
        <div class="d-flex align-items-start gap-2 mb-3">
          <i class="fa-solid fa-triangle-exclamation mt-1"></i>
          <p class="mb-0">Delete your account? This action can't be undone.</p>
        </div>
        <div class="d-flex gap-2">
          <button class="flex-fill profile-delete-confirm__cancel" data-bs-toggle="collapse" data-bs-target="#confirm-delete">
            Cancel
          </button>
          <%= button_to "Yes, delete", registration_path(:user), method: :delete, class: "flex-fill profile-delete-confirm__confirm", data: { turbo_confirm: false } %>
        </div>
      </div>
    </div>
  </div>

</div>
