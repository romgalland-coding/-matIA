<div class="container py-4">
  <h1 class="mb-4">Mon profil</h1>

  <div class="card mb-4">
    <div class="card-body">
      <h2 class="card-title h4">Informations personnelles</h2>

      <dl class="row mb-0">
        <dt class="col-sm-3">Nom d'utilisateur</dt>
        <dd class="col-sm-9"><%= @user.user_name %></dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9"><%= @user.email %></dd>

        <dt class="col-sm-3">Mot de passe</dt>
        <dd class="col-sm-9">••••••••</dd>
      </dl>

      <%= link_to "Modifier mon profil", edit_profile_path, class: "btn btn-primary mt-3" %>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <h2 class="card-title h4">Mes devices</h2>

      <% if @user.devices.present? %>
        <ul class="list-group list-group-flush">
          <% @user.devices.each do |device| %>
            <li class="list-group-item"><%= device %></li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-muted mb-0">Tu n'as pas encore ajouté de device.</p>
      <% end %>
    </div>
  </div>
</div>
