<div class="profile-page px-4 pt-5">

  <div class="profile-header mb-5">
    <div class="profile-avatar">
      <%= current_user.user_name.first(2).upcase %>
    </div>
    <div>
      <h1 class="profile-title">Edit profile</h1>
      <p class="profile-subtitle">Update your account &amp; devices</p>
    </div>
  </div>

  <%= simple_form_for @user, url: profile_path, method: :patch do |f| %>
    <div class="d-flex flex-column gap-3 mb-5">

      <div id="user_name">
        <%= f.input :user_name,
            label: "Username",
            wrapper_html: { class: "profile-field" },
            label_html: { class: "form-label" },
            input_html: { class: "form-control" } %>
      </div>

      <div id="email">
        <%= f.input :email,
            label: "Email",
            wrapper_html: { class: "profile-field" },
            label_html: { class: "form-label" },
            input_html: { class: "form-control" } %>
      </div>

      <div id="password">
        <%= f.input :password,
            label: "New password",
            hint: "Leave blank to keep current password",
            required: false,
            wrapper_html: { class: "profile-field" },
            label_html: { class: "form-label" },
            input_html: { class: "form-control" } %>

        <%= f.input :password_confirmation,
            label: "Confirm new password",
            required: false,
            wrapper_html: { class: "profile-field" },
            label_html: { class: "form-label" },
            input_html: { class: "form-control" } %>
      </div>

    </div>

    <div id="devices" class="mb-5">
      <label class="form-label">My devices</label>
      <div class="profile-devices-grid">
        <% User::PLATFORMS.each do |platform| %>
          <label class="profile-device-option <%= 'profile-device-option--selected' if @user.devices&.include?(platform) %>">
            <%= f.check_box :devices, { multiple: true, checked: @user.devices&.include?(platform), class: "profile-device-checkbox" }, platform, nil %>
            <span><%= platform %></span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="d-flex flex-column gap-3">
      <%= f.button :submit, "Save changes", class: "btn btn-primary w-100 py-3" %>
      <%= link_to "Cancel", profile_path, class: "btn btn-secondary w-100 py-3" %>
    </div>
  <% end %>

</div>
