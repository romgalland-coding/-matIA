<div class="home-page px-4 pt-5">

  <header class="text-center mb-4">
    <h1 class="home-title">meet <em>matIA</em></h1>
    <p class="home-subtitle">Discover your next favourite game.</p>
  </header>

  <% if @cover_images.any? %>
    <div class="home-grid mb-4">
      <% @cover_images.each do |url| %>
        <div class="home-grid__cell" style="background-image: url('<%= url %>')"></div>
      <% end %>
    </div>
  <% end %>

  <div class="home-features mb-4">
    <div class="home-feature">
      <div class="home-feature__icon"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
      <div>
        <p class="home-feature__title">AI-powered picks</p>
        <p class="home-feature__desc">Chat about what you're in the mood for — matIA does the rest.</p>
      </div>
    </div>
    <hr class="home-feature__divider">
    <div class="home-feature">
      <div class="home-feature__icon"><i class="fa-solid fa-gamepad"></i></div>
      <div>
        <p class="home-feature__title">Personalised to you</p>
        <p class="home-feature__desc">The more you use it, the smarter your recommendations get.</p>
      </div>
    </div>
    <hr class="home-feature__divider">
    <div class="home-feature">
      <div class="home-feature__icon"><i class="fa-solid fa-list-check"></i></div>
      <div>
        <p class="home-feature__title">Organise your library</p>
        <p class="home-feature__desc">Track what you own and build a wishlist of what's next.</p>
      </div>
    </div>
  </div>

  <div class="d-flex flex-column gap-3">
    <% if user_signed_in? %>
      <%= button_to chats_path, method: :post, class: "btn btn-primary w-100 py-3 home-cta" do %>
        <i class="fa-solid fa-message me-2"></i>Start chatting
      <% end %>
    <% else %>
      <%= link_to new_user_registration_path, class: "btn btn-primary w-100 py-3 home-cta" do %>
        <i class="fa-solid fa-message me-2"></i>Create an account
      <% end %>
      <%= link_to "I already have an account", new_user_session_path, class: "home-signin-link text-center" %>
    <% end %>
  </div>

</div>
