<div class="game-show px-4 pt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <%= link_to games_path, class: "btn btn-secondary btn-sm" do %>
      <i class="fa-solid fa-chevron-left"></i> Back
    <% end %>
    <span class="chip chip-yellow">
      <i class="fa-solid <%= @game.collection_status == 'owned' ? 'fa-check' : 'fa-heart' %>"></i>
      <%= @game.collection_status.capitalize %>
    </span>
  </div>

  <% if @game.genre.present? %>
    <p class="text-uppercase fw-semibold text-muted small mb-1"><%= @game.genre %></p>
  <% end %>
  <div class="d-flex align-items-center gap-3 mb-3">
    <h1 class="fw-bold mb-0" style="font-size: 2rem; line-height: 1.1;"><%= @game.title %></h1>
    <% if @game.metacritic.present? %>
      <span class="metacritic-badge metacritic-badge--lg metacritic-badge--<%= @game.metacritic_color %>">
        <%= @game.metacritic %>
      </span>
    <% end %>
  </div>

  <% if @game.cover_image.present? %>
    <div class="game-show__hero mb-3" style="background-image: url('<%= @game.cover_image %>')"></div>
  <% end %>

  <% if @game.platform.present? %>
    <div class="d-flex flex-wrap gap-2 mb-3">
      <% Array(@game.platform).each do |p| %>
        <span class="chip chip-green"><%= p %></span>
      <% end %>
    </div>
  <% end %>

  <% if @game.description.present? %>
    <h2 class="fw-bold mb-1" style="font-size: 1.25rem;">Description</h2>
    <div class="card card-flat p-3 mb-2">
      <p class="mb-0" style="font-size: 0.9375rem; line-height: 1.6;"><%= @game.description %></p>
    </div>
  <% end %>

<div class="d-flex gap-2 mb-2 flex-wrap">
  <% if @game.studio.present? %>
    <span class="chip chip-green"><%= @game.studio %></span>
  <% end %>
  <% if @game.release_date.present? %>
    <span class="chip chip-green"><%= @game.release_date.strftime("%b %-d, %Y") %></span>
  <% end %>
  <% if @game.sales.present? %>
    <span class="chip chip-green"><%= "#{number_with_delimiter(@game.sales)} sales" %></span>
  <% end %>
</div>

  <% if @game.collection_status == "pending" %>
    <%= button_to game_path(@game), method: :patch, params: { collection_status: "wishlist" }, class: "btn btn-primary w-100 py-3" do %>
      <i class="fa-solid fa-heart"></i> Add to wishlist
    <% end %>
  <% else %>
    <%= button_to game_path(@game), method: :patch, params: { collection_status: "played" }, class: "btn btn-primary w-100 py-3" do %>
      <i class="fa-solid fa-check"></i> Mark as played
    <% end %>
  <% end %>

  <% if @similar_games.any? %>
  <div class="mt-4">
    <h2 class="fw-bold mb-3" style="font-size: 1.25rem;">Similar games</h2>
    <div class="games-grid">
      <% @similar_games.each do |game| %>
        <%= render "games/similar_game_card", game: game %>
      <% end %>
    </div>
  </div>
  <% end %>

</div>
