<div class="games-page px-4 pt-5" data-controller="edit-mode">

  <div class="games-title-row">
    <h1 class="games-title">My library</h1>
    <button id="edit-btn" class="game-edit-btn d-none" data-action="click->edit-mode#toggle">
      <i class="fa-solid fa-pen-to-square"></i> Edit
    </button>
  </div>
  <p class="games-subtitle">Keep track of what you love and want next.</p>

  <%# Tab switcher %>
  <div class="games-tabs mb-4">
    <button class="games-tab games-tab--active" data-tab="wishlist" onclick="switchTab('wishlist')">
      <i class="fa-solid fa-heart"></i> Wishlist
    </button>
    <button class="games-tab" data-tab="owned" onclick="switchTab('owned')">
      <i class="fa-solid fa-check"></i> My Games
    </button>
  </div>

  <%# Wishlist tab %>
  <% wishlist_games = @games.select { |g| g.collection_status == "wishlist" } %>
  <div id="tab-wishlist" class="games-grid">
    <% if wishlist_games.any? %>
      <% wishlist_games.each do |game| %>
        <div class="game-card">
          <%= link_to game_path(game), class: "game-card__link" do %>
            <div class="game-card__cover" <% if game.cover_image.present? %>style="background-image: url('<%= game.cover_image %>')"<% end %>>
              <% unless game.cover_image.present? %>
                <span class="game-card__cover-placeholder"><i class="fa-solid fa-gamepad"></i></span>
              <% end %>
              <% if game.metacritic.present? %>
                <span class="metacritic-badge metacritic-badge--<%= game.metacritic >= 75 ? 'green' : (game.metacritic >= 50 ? 'yellow' : 'red') %>">
                  <%= game.metacritic %>
                </span>
              <% end %>
            </div>
            <div class="game-card__body">
              <p class="game-card__title"><%= game.title %></p>
              <p class="game-card__genre"><%= game.genre %></p>
              <% if game.platform.present? %>
                <span class="game-card__platform"><%= Array(game.platform).first %></span>
              <% end %>
            </div>
          <% end %>
          <div class="game-card__footer">
            <%= button_to game_path(game), method: :patch, params: { collection_status: "played" }, class: "game-card__action game-card__action--blue" do %>
              <i class="fa-solid fa-gamepad"></i> Mark played
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="games-empty">No games in your wishlist yet. <br><a href="#" onclick="createChat(event)">Start a chat to add some →</a></p>
    <% end %>
  </div>

  <%# Owned tab %>
  <% owned_games = @games.select { |g| g.collection_status == "played" } %>
  <div id="tab-owned" class="d-none">
    <div class="owned-section" data-edit-mode-target="ownedSection">
      <% if owned_games.any? %>
        <div class="games-grid">
          <% owned_games.each do |game| %>
            <div class="game-card">
              <%= link_to game_path(game), class: "game-card__link" do %>
                <div class="game-card__cover" <% if game.cover_image.present? %>style="background-image: url('<%= game.cover_image %>')"<% end %>>
                  <% unless game.cover_image.present? %>
                    <span class="game-card__cover-placeholder"><i class="fa-solid fa-gamepad"></i></span>
                  <% end %>
                  <% if game.metacritic.present? %>
                    <span class="metacritic-badge metacritic-badge--<%= game.metacritic >= 75 ? 'green' : (game.metacritic >= 50 ? 'yellow' : 'red') %>">
                      <%= game.metacritic %>
                    </span>
                  <% end %>
                </div>
                <div class="game-card__body">
                  <p class="game-card__title"><%= game.title %></p>
                  <p class="game-card__genre"><%= game.genre %></p>
                  <% if game.platform.present? %>
                    <span class="game-card__platform"><%= Array(game.platform).first %></span>
                  <% end %>
                </div>
              <% end %>
              <%= button_to game_path(game), method: :delete, class: "game-card__delete-btn", form: { class: "game-card__delete-form" }, data: { action: "click->confirm#show", game_title: game.title, game_cover: game.cover_image } do %>
                <i class="fa-solid fa-xmark"></i>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="games-empty">No played games yet.</p>
      <% end %>
    </div>
  </div>

  <div id="discover-btn" class="mt-4 mb-2 <%= wishlist_games.any? ? '' : 'd-none' %>">
    <%= button_to chats_path, method: :post, class: "btn btn-success w-100 py-3 games-discover" do %>
      <i class="fa-solid fa-plus me-2"></i>Discover more with matIA
    <% end %>
  </div>

  <%# Hidden form for creating a new chat via link %>
  <%= form_with url: chats_path, method: :post, id: "new-chat-form" do |f| %>
  <% end %>

</div>

<script>
  const wishlistHasGames = <%= wishlist_games.any?.to_json %>;
  const ownedHasGames = <%= owned_games.any?.to_json %>;

  function switchTab(tab) {
    document.querySelectorAll('.games-tab').forEach(el => el.classList.remove('games-tab--active'));
    document.querySelector(`[data-tab="${tab}"]`).classList.add('games-tab--active');
    document.getElementById('tab-wishlist').classList.toggle('d-none', tab !== 'wishlist');
    document.getElementById('tab-owned').classList.toggle('d-none', tab !== 'owned');
    document.getElementById('edit-btn').classList.toggle('d-none', tab !== 'owned');

    const hasGames = tab === 'wishlist' ? wishlistHasGames : ownedHasGames;
    document.getElementById('discover-btn').classList.toggle('d-none', !hasGames);
  }

  function createChat(event) {
    event.preventDefault();
    document.getElementById('new-chat-form').submit();
  }

  // Check URL parameter for initial tab
  function initializeTab() {
    const urlParams = new URLSearchParams(window.location.search);
    const initialTab = urlParams.get('tab') || 'wishlist';
    if (initialTab === 'owned') {
      switchTab('owned');
    }
  }

  document.addEventListener('turbo:load', initializeTab);
  initializeTab();
</script>
