<div class="games-page px-4 pt-5" data-controller="edit-mode">

  <div class="games-title-row">
    <h1 class="games-title">My library</h1>
    <button id="edit-btn" class="game-edit-btn d-none" data-action="click->edit-mode#toggle">
      <i class="fa-solid fa-pen-to-square"></i> Edit
    </button>
  </div>
  <p class="games-subtitle">Keep track of what you love and want next.</p>

  <div class="games-sort-container mb-4">
    <button id="games-sort-toggle" type="button" class="btn btn-secondary games-sort-toggle" aria-expanded="false" aria-controls="games-sort-panel" onclick="toggleSortPanel()">
      <i class="fa-solid fa-filter me-2"></i> Sort/filter
    </button>

    <div id="games-sort-panel" class="games-sort-panel d-none">
      <%= form_with url: games_path, method: :get, local: true, class: "games-filter-form" do %>
        <div class="games-sort-row">
          <span class="games-sort-label">Sort by</span>
          <div class="games-sort-group">
            <%= button_tag "Title", type: "button", class: "games-sort-button #{'games-sort-button--active' if @sort == 'title'}", data: { sort_value: 'title' } %>
            <%= button_tag "Added date", type: "button", class: "games-sort-button #{'games-sort-button--active' if @sort == 'added_date'}", data: { sort_value: 'added_date' } %>
            <%= button_tag "Rating", type: "button", class: "games-sort-button #{'games-sort-button--active' if @sort == 'metacritic'}", data: { sort_value: 'metacritic' } %>
          </div>
        </div>
        <div class="games-sort-row">
          <span class="games-sort-label">Order</span>
          <div class="games-sort-group">
            <%= button_tag "Ascending", type: "button", class: "games-sort-button #{'games-sort-button--active' if @direction == 'asc'}", data: { direction_value: 'asc' } %>
            <%= button_tag "Descending", type: "button", class: "games-sort-button #{'games-sort-button--active' if @direction == 'desc'}", data: { direction_value: 'desc' } %>
          </div>
        </div>
        <div class="games-sort-row">
          <span class="games-sort-label">Filter by</span>
          <div class="games-sort-group games-filter-group">
            <div class="games-filter-field mb-2">
              <label for="platform">Platform</label>
              <%= select_tag :platform, options_for_select([['All platforms', '']] + @platform_options.map { |p| [p, p] }, @selected_platform), id: 'platform', class: 'form-select' %>
            </div>
            <div class="games-filter-field mb-2">
              <label for="genre">Genre</label>
              <%= select_tag :genre, options_for_select([['All genres', '']] + @genre_options.map { |g| [g, g] }, @selected_genre), id: 'genre', class: 'form-select' %>
            </div>
            <div class="games-filter-field mb-2">
              <label for="studio">Studio</label>
              <%= select_tag :studio, options_for_select([['All studios', '']] + @studio_options.map { |s| [s, s] }, @selected_studio), id: 'studio', class: 'form-select' %>
            </div>
          </div>
        </div>
        <%= hidden_field_tag :sort, @sort, id: 'sort-field' %>
        <%= hidden_field_tag :direction, @direction, id: 'direction-field' %>
        <%= hidden_field_tag :tab, params[:tab], id: 'tab-field' %>
        <%= hidden_field_tag :panel_open, params[:panel_open], id: 'panel-open-field' %>
        <div class="games-filter-actions mt-3">
          <%= submit_tag "Apply", class: "games-sort-button btn btn-primary me-2" %>
          <%= button_tag "Clear", type: "button", id: "clear-filters-button", class: "games-sort-button btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Tab switcher %>
  <div class="games-tabs mb-4">
    <button class="games-tab games-tab--active" data-tab="wishlist" onclick="switchTab('wishlist')">
      <i class="fa-solid fa-heart"></i> Wishlist
    </button>
    <button class="games-tab" data-tab="owned" onclick="switchTab('owned')">
      <i class="fa-solid fa-check"></i> My Games
    </button>
  </div>

  <%# Wishlist tab %>
  <% wishlist_games = @games.select { |g| g.collection_status == "wishlist" } %>
  <div id="tab-wishlist" class="games-grid">
    <% if wishlist_games.any? %>
      <% wishlist_games.each do |game| %>
        <div class="game-card">
          <%= link_to game_path(game), class: "game-card__link" do %>
            <div class="game-card__cover" <% if game.cover_image.present? %>style="background-image: url('<%= game.cover_image %>')"<% end %>>
              <% unless game.cover_image.present? %>
                <span class="game-card__cover-placeholder"><i class="fa-solid fa-gamepad"></i></span>
              <% end %>
              <% if game.metacritic.present? %>
                <span class="metacritic-badge metacritic-badge--<%= game.metacritic_color %>">
                  <%= game.metacritic %>
                </span>
              <% end %>
            </div>
            <div class="game-card__body">
              <p class="game-card__title"><%= game.title %></p>
              <p class="game-card__genre"><%= game.genre %></p>
            </div>
          <% end %>
          <div class="game-card__footer">
            <%= button_to game_path(game), method: :patch, params: { collection_status: "played" }, class: "game-card__action game-card__action--blue" do %>
              <i class="fa-solid fa-gamepad"></i> Mark played
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="games-empty">No games in your wishlist yet. <br><a href="#" onclick="createChat(event)">Start a chat to add some →</a></p>
    <% end %>
  </div>

  <%# Owned tab %>
  <% owned_games = @games.select { |g| g.collection_status == "played" } %>
  <div id="tab-owned" class="d-none">
    <div class="owned-section" data-edit-mode-target="ownedSection">
      <% if owned_games.any? %>
        <div class="games-grid">
          <% owned_games.each do |game| %>
            <div class="game-card">
              <%= link_to game_path(game), class: "game-card__link" do %>
                <div class="game-card__cover" <% if game.cover_image.present? %>style="background-image: url('<%= game.cover_image %>')"<% end %>>
                  <% unless game.cover_image.present? %>
                    <span class="game-card__cover-placeholder"><i class="fa-solid fa-gamepad"></i></span>
                  <% end %>
                  <% if game.metacritic.present? %>
                    <span class="metacritic-badge metacritic-badge--<%= game.metacritic_color %>">
                      <%= game.metacritic %>
                    </span>
                  <% end %>
                </div>
                <div class="game-card__body">
                  <p class="game-card__title"><%= game.title %></p>
                  <p class="game-card__genre"><%= game.genre %></p>
                  <% if game.platform.present? %>
                    <span class="game-card__platform"><%= Array(game.platform).first %></span>
                  <% end %>
                </div>
              <% end %>
              <%= button_to game_path(game), method: :delete, class: "game-card__delete-btn", form: { class: "game-card__delete-form" }, data: { action: "click->confirm#show", game_title: game.title, game_cover: game.cover_image } do %>
                <i class="fa-solid fa-xmark"></i>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="games-empty">No played games yet.</p>
      <% end %>
    </div>
  </div>

  <div id="discover-btn" class="mt-4 mb-2 <%= wishlist_games.any? ? '' : 'd-none' %>">
    <%= button_to chats_path, method: :post, class: "btn btn-success w-100 py-3 games-discover" do %>
      <i class="fa-solid fa-plus me-2"></i>Discover more with matIA
    <% end %>
  </div>

  <%# Hidden form for creating a new chat via link %>
  <%= form_with url: chats_path, method: :post, id: "new-chat-form" do |f| %>
  <% end %>

</div>

<script>
  const wishlistHasGames = <%= wishlist_games.any?.to_json %>;
  const ownedHasGames = <%= owned_games.any?.to_json %>;

  function switchTab(tab) {
    document.querySelectorAll('.games-tab').forEach(el => el.classList.remove('games-tab--active'));
    document.querySelector(`[data-tab="${tab}"]`).classList.add('games-tab--active');
    document.getElementById('tab-wishlist').classList.toggle('d-none', tab !== 'wishlist');
    document.getElementById('tab-owned').classList.toggle('d-none', tab !== 'owned');
    document.getElementById('edit-btn').classList.toggle('d-none', tab !== 'owned');

    const hasGames = tab === 'wishlist' ? wishlistHasGames : ownedHasGames;
    document.getElementById('discover-btn').classList.toggle('d-none', !hasGames);
    const tabField = document.getElementById('tab-field');
    if (tabField) tabField.value = tab;
  }

  function createChat(event) {
    event.preventDefault();
    document.getElementById('new-chat-form').submit();
  }

  function toggleSortPanel() {
    const panel = document.getElementById('games-sort-panel');
    const button = document.getElementById('games-sort-toggle');
    const isHidden = panel.classList.toggle('d-none');
    button.setAttribute('aria-expanded', String(!isHidden));
  }

  function initSortFilterButtons() {
    document.querySelectorAll('[data-sort-value]').forEach(button => {
      button.addEventListener('click', () => {
        document.getElementById('sort-field').value = button.dataset.sortValue;
        updateActiveButton('[data-sort-value]', button);
      });
    });

    document.querySelectorAll('[data-direction-value]').forEach(button => {
      button.addEventListener('click', () => {
        document.getElementById('direction-field').value = button.dataset.directionValue;
        updateActiveButton('[data-direction-value]', button);
      });
    });

    const clearButton = document.getElementById('clear-filters-button');
    const form = document.querySelector('.games-filter-form');
    if (clearButton && form) {
      clearButton.addEventListener('click', () => {
        document.getElementById('platform').value = '';
        document.getElementById('genre').value = '';
        document.getElementById('studio').value = '';
        // keep panel open after clear
        const panelField = document.getElementById('panel-open-field');
        if (panelField) panelField.value = '1';
        // submit form to apply clear immediately
        form.submit();
        // remove focus so button doesn't stay highlighted
        clearButton.blur();
      });
    }
  }

  function updateActiveButton(selector, activeButton) {
    document.querySelectorAll(selector).forEach(btn => btn.classList.remove('games-sort-button--active'));
    activeButton.classList.add('games-sort-button--active');
  }

  // Check URL parameter for initial tab
  function initializeTab() {
    const urlParams = new URLSearchParams(window.location.search);
    const initialTab = urlParams.get('tab') || 'wishlist';
    if (initialTab === 'owned') switchTab('owned');
    // open panel if requested (clear submits with panel_open=1)
    const panelOpen = urlParams.get('panel_open');
    if (panelOpen === '1') {
      const panel = document.getElementById('games-sort-panel');
      if (panel.classList.contains('d-none')) {
        toggleSortPanel();
      }
    }
  }

  document.addEventListener('turbo:load', () => {
    initializeTab();
    initSortFilterButtons();
  });
  initializeTab();
  initSortFilterButtons();
</script>
